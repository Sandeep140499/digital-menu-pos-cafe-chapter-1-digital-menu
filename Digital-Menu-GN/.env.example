# Frontend (Vite) - copy to .env and set for production

# Staff stay signed in via backend httpOnly refresh cookie + short access JWT.
# No extra JWT variables needed here.

# Backend API base URL. In dev, /api is proxied; in production set to your API origin.
VITE_API_BASE_URL=https://digital-menu-api-production.up.railway.app/api

# Optional: lock this build to one restaurant branch (Prisma Branch.id).
# VITE_PUBLIC_BRANCH_ID=2

# Deployed frontend URL for redirects and links. Used by getFrontendUrl().
VITE_FRONTEND_URL=https://your-frontend.vercel.app
