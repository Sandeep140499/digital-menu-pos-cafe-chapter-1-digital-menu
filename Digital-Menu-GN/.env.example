# Frontend (Vite) – copy to .env and set for production

# Backend API base URL. In dev, /api is proxied; in production set to your API origin.
# VITE_API_BASE_URL=https://your-api.example.com/api

# Deployed frontend URL for redirects and links. Used by getFrontendUrl().
# Set in production so email verification / password reset links point to your domain, not localhost.
# VITE_FRONTEND_URL=https://yourdomain.com
