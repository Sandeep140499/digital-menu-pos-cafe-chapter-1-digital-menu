NODE_ENV=development
PORT=4000

# Scaling / stability
# - ENABLE_CLUSTER=true will start multiple Node workers (same port) for higher concurrency.
# - WEB_CONCURRENCY sets worker count (capped to CPU count).
ENABLE_CLUSTER="false"
WEB_CONCURRENCY=1
# If running behind a load balancer / reverse proxy (Render/Railway/Nginx), keep this enabled
# so client IPs are correct (rate limiting, logs) and secure cookies work properly.
TRUST_PROXY="true"

# Request protection (prevents slow/huge requests from crashing the server)
JSON_BODY_LIMIT="1mb"
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
KEEP_ALIVE_TIMEOUT_MS=65000

# Basic API rate limiting (in-memory, per process/worker)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# PostgreSQL (Railway / free tier)
# Recommended pooling for Railway free DB (keeps connections low but stable for ~20+ users):
# - Use a SMALL pool per backend instance, then scale via fewer instances (ideally 1 on free tier).
# - If Railway provides a PgBouncer/Pooler URL, prefer that as DATABASE_URL.
#
# Suggested params (Prisma):
# - connection_limit=5        (5 connections max from this backend process)
# - pool_timeout=30           (wait up to 30s for a free connection under spikes)
# - statement_timeout=60000   (optional: prevent runaway queries)
#
# Example:
# DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB?sslmode=require&connection_limit=5&pool_timeout=30"
DATABASE_URL="postgresql://postgres:replace-me@mainline.proxy.rlwy.net:19013/railway?sslmode=require&connection_limit=5&pool_timeout=30"

# JWT
JWT_SECRET="replace-with-strong-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REFRESH_TOKEN_SALT="replace-with-strong-random-salt"

# Auth cookies
# - If frontend + backend are on different domains, use AUTH_COOKIE_SAMESITE="none" (requires https).
# - If same-site, prefer "lax" or "strict".
AUTH_COOKIE_SAMESITE="lax"
# AUTH_COOKIE_DOMAIN=".yourdomain.com"

# SMTP / Brevo (welcome email, verify employee, forgot password, salary slip email)
# Configure with your Brevo SMTP credentials. Password/key is trimmed safely by the mailer.
EMAIL_FROM_NAME="Gautam Nagar Digital Menu POS"
EMAIL_FROM_ADDRESS="your-verified-sender@yourdomain.com"
EMAIL_SMTP_HOST="smtp-relay.brevo.com"
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER="a50997001@smtp-brevo.com"
EMAIL_SMTP_PASS="your-brevo-smtp-key"

# Brevo HTTP API (recommended for production platforms that block SMTP ports)
# If set, backend will send emails via API (SMTP becomes fallback).
BREVO_API_KEY="your-brevo-api-key"

# Frontend URLs (local dev – customer + dashboard). In production, use FRONTEND_URL instead.
FRONTEND_CUSTOMER_URL="http://localhost:5173"
FRONTEND_DASHBOARD_URL="http://localhost:5173"
FRONTEND_URL="https://your-production-frontend-domain"

# CORS (Vercel admin + customer calling Railway API):
# Backend merges CORS_ORIGIN + FRONTEND_URL + FRONTEND_CUSTOMER_URL + FRONTEND_DASHBOARD_URL (comma-separated).
# Include every deployed origin, e.g. https://your-app-dig.vercel.app (no trailing slash).
# If NONE of these are set, all origins are allowed (dev only — set in production).
# CORS_ORIGIN="https://your-app-dig.vercel.app"

# Optional: protect /api/metrics (Prometheus scrape). Set a long random string.
# Access with header: Authorization: Bearer <METRICS_TOKEN>
METRICS_TOKEN="replace-with-long-random-token"

# Google Review
GOOGLE_REVIEW_URL="https://g.page/r/CekUwwDsaYMBEAE/review"

# After the monthly director PDF email succeeds (1st of month ~04:10 branch TZ), delete only orders whose
# createdAt falls in the reported (previous) calendar month — same window as the PDF. Older months stay in DB.
# Order id AUTO INCREMENT continues (e.g. next order after 100 is 101). Daily director email: dailyDirectorReport.
ORDER_PURGE_AFTER_MONTHLY_REPORT="false"