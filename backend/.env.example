NODE_ENV=development
PORT=4000

# PostgreSQL (Railway)
# IMPORTANT (concurrency / pooling):
# - For 50+ concurrent users, use a pooled DB URL if your provider offers it (PgBouncer/Pooler).
# - If using Prisma direct DB URL, keep connection limits reasonable to avoid exhausting DB connections.
# Example:
# DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB?sslmode=require&connection_limit=20&pool_timeout=20"
DATABASE_URL="postgresql://postgres:likgWYTabUSEFvJOmFiSlFwKWLDdGBOt@mainline.proxy.rlwy.net:19013/railway?sslmode=require&connection_limit=20&pool_timeout=20"

# JWT
JWT_SECRET="replace-with-strong-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REFRESH_TOKEN_SALT="replace-with-strong-random-salt"

# Auth cookies
# - If frontend + backend are on different domains, use AUTH_COOKIE_SAMESITE="none" (requires https).
# - If same-site, prefer "lax" or "strict".
AUTH_COOKIE_SAMESITE="lax"
# AUTH_COOKIE_DOMAIN=".yourdomain.com"

# SMTP / Brevo (welcome email, verify employee, forgot password, salary slip email)
# Configure with your Brevo SMTP credentials. Password/key is trimmed safely by the mailer.
EMAIL_FROM_NAME="Gautam Nagar Digital Menu POS"
EMAIL_FROM_ADDRESS="your-verified-sender@yourdomain.com"
EMAIL_SMTP_HOST="smtp-relay.brevo.com"
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER="a50997001@smtp-brevo.com"
EMAIL_SMTP_PASS="your-brevo-smtp-key"

# Brevo HTTP API (recommended for production platforms that block SMTP ports)
# If set, backend will send emails via API (SMTP becomes fallback).
BREVO_API_KEY="your-brevo-api-key"

# Frontend URLs (local dev – customer + dashboard). In production, use FRONTEND_URL instead.
FRONTEND_CUSTOMER_URL="http://localhost:5173"
FRONTEND_DASHBOARD_URL="http://localhost:5173"
FRONTEND_URL="https://your-production-frontend-domain"

# Optional: comma-separated origins for CORS (e.g. https://your-frontend.onrender.com). If unset, all origins are allowed.
# CORS_ORIGIN="https://your-frontend.onrender.com"

# Optional: protect /api/metrics (Prometheus scrape). Set a long random string.
# Access with header: Authorization: Bearer <METRICS_TOKEN>
METRICS_TOKEN="replace-with-long-random-token"

# Google Review
GOOGLE_REVIEW_URL="https://g.page/r/CekUwwDsaYMBEAE/review"