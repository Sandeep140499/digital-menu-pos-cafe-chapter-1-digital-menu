# Copy to /etc/nginx/sites-available/ and symlink into sites-enabled.
# Replace api.example.com with your hostname; point DNS A/AAAA to this EC2 (Elastic IP recommended).
# After HTTP works: sudo certbot --nginx -d api.example.com
#
# Upstream: Node listens on PORT (default 4000). Set in backend/.env.

upstream pos_api {
  server 127.0.0.1:4000;
  keepalive 32;
}

server {
  listen 80;
  listen [::]:80;
  server_name api.example.com;

  location /api/ {
    proxy_pass http://pos_api/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
  }

  location /socket.io/ {
    proxy_pass http://pos_api/socket.io/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 86400;
  }
}
