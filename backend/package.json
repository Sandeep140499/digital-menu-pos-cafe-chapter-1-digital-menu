{
  "name": "digital-menu-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js --exec node --loader ts-node/esm src/index.ts",
    "build": "prisma generate && tsc",
    "prestart": "prisma migrate deploy",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest run --config vitest.config.ts --watch",
    "loadtest:menu": "k6 run load-tests/k6-menu.js",
    "loadtest:order": "k6 run load-tests/k6-order.js",
    "loadtest:mixed": "k6 run load-tests/k6-mixed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "seed": "node --loader ts-node/esm src/seed.ts",
    "migrate:menu": "node --loader ts-node/esm src/migrate-menu.ts",
    "import:chapter1-menu": "node --loader ts-node/esm src/import-chapter-one-menu.ts",
    "import:customer-leads": "node --loader ts-node/esm src/import-customer-leads.ts",
    "seed:migrate": "node --loader ts-node/esm src/seed-menu-migrate.ts",
    "reset-db-keep-menu": "node --loader ts-node/esm src/reset-db-keep-menu.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
